{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServer": "",
    "Redis": "",
    "MongoDB": ""
  },
  "Jwt": {
    "Issuer": "Quantira",
    "Audience": "QuantiraClient",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "MarketData": {
    "Provider": "Yahoo",
    "RefreshIntervalSeconds": 15,
    "CryptoProvider": "Binance"
  },
  "Hangfire": {
    "DashboardPath": "/jobs",
    "WorkerCount": 5
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information" }
  }
}
